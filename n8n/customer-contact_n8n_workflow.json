    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const body = $json.body;\n\nconst normalized = {\n  source_channel: 'webhook',\n  customer_name: body.name ?? '',\n  customer_email: body.email ?? '',\n  customer_phone: body.phone ?? '',\n  subject: body.subject ?? '',\n  text: body.message ?? ''\n};\n\nreturn {\n  json: normalized\n};"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        208,
        0
      ],
      "id": "8c8925c3-6088-4c8a-965e-e72b72d4ec4a",
      "name": "Normalize Webhook"
    },
    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const normalized = {\n  source_channel: 'audio',\n  customer_name:  '',\n  customer_email: '',\n  customer_phone: $json.body.phone ?? '',\n  subject: '',\n  text: $json.transcript_text ?? '',\n};\n\nreturn {\n  json: normalized\n};"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        272,
        512
      ],
      "id": "377a1938-9e7d-45d5-9ae7-7a284a0131a0",
      "name": "Normalize Audio Upload"
    },
    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const from_match = $json.from.match(/^(.+?)\\s*<(.+?)>$/);\n\nlet name = \"\";\nlet email = \"\";\n\nif (from_match) {\n  name = from_match[1];\n  email = from_match[2];\n}\n\nconst normalized = {\n  source_channel: 'email',\n  customer_name: name ?? '',\n  customer_email: email ?? '',\n  customer_phone: '',\n  subject: $json.subject ?? '',\n  text: $json.textPlain ?? ''\n};\n\nreturn {\n  json: normalized\n};"
      },
