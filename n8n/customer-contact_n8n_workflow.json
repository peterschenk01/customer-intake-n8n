        "inputSchema": "{\n  \"type\": \"object\",\n  \"properties\": {\n    \"summary\": {\n      \"type\": \"string\",\n      \"description\": \"Kurze Zusammenfassung in 2 bis 3 Sätzen auf Deutsch\"\n    },\n    \"sentiment\": {\n      \"type\": \"string\",\n      \"enum\": [\"good\", \"neutral\", \"bad\"]\n    },\n    \"open_todo\": {\n      \"type\": \"boolean\",\n      \"description\": \"True, wenn ein Rückruf, eine Klärung, ein Termin oder eine andere Aktion offen ist\"\n    }\n  },\n  \"required\": [\"summary\", \"sentiment\", \"open_todo\"]\n}",
